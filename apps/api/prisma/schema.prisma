datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model RoleChangeEvent {
  id             String   @id @default(uuid())
  eventId        String   @unique
  employeeId     String
  transitionType String
  timestamp      DateTime
  oldDetails     Json
  newDetails     Json
  status         String   @default("RECEIVED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accessReview AccessReviewRequest?
}

model AccessReviewRequest {
  id         String   @id @default(uuid())
  reviewId   String   @unique
  eventId    String   @unique
  employeeId String
  status     String   @default("PENDING_RECOMMENDATION")
  riskLevel  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  roleChangeEvent RoleChangeEvent      @relation(fields: [eventId], references: [eventId])
  recommendations RecommendationItem[]
  auditLogs       AuditLog[]
}

model RecommendationItem {
  id             String   @id @default(uuid())
  reviewId       String
  systemName     String
  entitlementKey String
  action         String
  reason         String
  policyCitation String
  confidence     Float
  createdAt      DateTime @default(now())

  accessReview AccessReviewRequest @relation(fields: [reviewId], references: [reviewId])
}

model EmployeeEntitlement {
  id             String   @id @default(uuid())
  employeeId     String
  systemName     String
  entitlementKey String
  accessLevel    String
  isActive       Boolean  @default(true)
  grantedAt      DateTime
  updatedAt      DateTime @updatedAt

  @@index([employeeId])
}

model ApprovalDecision {
  id            String   @id @default(uuid())
  reviewId      String
  reviewerEmail String
  decision      String
  comments      String?
  createdAt     DateTime @default(now())

  @@index([reviewId])
}

model ExecutionTask {
  id             String   @id @default(uuid())
  reviewId       String
  systemName     String
  entitlementKey String
  action         String
  status         String   @default("PENDING")
  attempts       Int      @default(0)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([reviewId])
}

model AuditLog {
  id         String   @id @default(uuid())
  traceId    String
  actor      String
  action     String
  entityType String
  entityId   String
  details    Json
  createdAt  DateTime @default(now())

  accessReviewId String?
  accessReview   AccessReviewRequest? @relation(fields: [accessReviewId], references: [id])

  @@index([traceId])
  @@index([entityType, entityId])
}

model LlmEvaluationMetric {
  id               String   @id @default(uuid())
  reviewId         String
  provider         String
  modelName        String
  latencyMs        Int
  inputTokens      Int
  outputTokens     Int
  estimatedCostUsd Float
  groundingScore   Float
  schemaValid      Boolean
  createdAt        DateTime @default(now())

  @@index([reviewId])
}
